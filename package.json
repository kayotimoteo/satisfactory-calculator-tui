{
  "name": "satisfactory-calculator-tui",
  "version": "0.3.1",
  "description": "Calculadora de fábrica do Satisfactory rodando no terminal (TUI), feita com OpenTUI + React sobre Bun.",
  "license": "MIT",
  "author": "Kayo Timoteo Rossales",
  "module": "src/index.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "sfcalc": "src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "i18n:build": "intlayer build",
    "typecheck": "tsc --noEmit",
    "build:exe": "bun run scripts/build-exe.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "19",
    "rcedit": "^5.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.3.0",
    "@opentui/react": "^0.3.0",
    "intlayer": "^8.12.0",
    "react": "^19.2.6"
  }
}
